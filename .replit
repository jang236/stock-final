run = "uvicorn main:app --host 0.0.0.0 --port 8000 --proxy-headers --forwarded-allow-ips=*"
entrypoint = "main.py"
modules = ["python-3.11", "postgresql-16"]

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8000
externalPort = 80


[deployment]
build = ["sh", "-c", "pip install -r requirements.txt"]
run = ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--proxy-headers", "--forwarded-allow-ips=*"]
deploymentTarget = "gce"

[nix]
packages = ["geckodriver", "glibcLocales", "libxcrypt", "sam", "xcodebuild", "zlib"]
channel = "stable-25_05"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api-server"

[[workflows.workflow]]
name = "api-server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uvicorn main:app --host 0.0.0.0 --port 8000 --proxy-headers --forwarded-allow-ips=*"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "webview"
