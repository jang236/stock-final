run = "python main.py"
entrypoint = "main.py"

[nix]
channel = "stable-22_11"

[env]
PYTHONPATH = "/home/runner/${REPL_SLUG}"
PORT = "8000"

[deployment]
run = ["sh", "-c", "uvicorn main:app --host 0.0.0.0 --port $PORT"]
deploymentTarget = "autoscale"

[[ports]]
localPort = 8000
externalPort = 80

[languages]

[languages.python3]
pattern = "**/*.py"

[languages.python3.languageServer]
start = "pylsp"
