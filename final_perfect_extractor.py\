    def _extract_company_name(self, soup: BeautifulSoup) -> str:
        """회사명 추출 - 검증된 방식"""
        try:
            title = soup.find('title')
            if title:
                title_text = title.get_text()
                if ':' in title_text:
                    name = title_text.split(':')[0].strip()
                    if name and 2 <= len(name) <= 30:
                        return name
            return "Unknown"
        except:
            return "Unknown"

    def _extract_current_price_verified(self, soup: BeautifulSoup) -> float:
        """현재가 추출 - 검증된 방식"""
        try:
            print("🔍 현재가 추출 (검증된 방식)...")
            
            # 검증된 방식: p.no_today > span.blind
            today_area = soup.find('p', class_='no_today')
            if today_area:
                blind_elem = today_area.find('span', class_='blind')
                if blind_elem:
                    text = blind_elem.get_text(strip=True)
                    if text and ',' in text:
                        cleaned = text.replace(',', '')
                        if cleaned.isdigit():
                            price = float(cleaned)
                            if 10 <= price <= 10000000:
                                return price
            return 0.0
        except Exception as e:
            print(f"❌ 현재가 추출 오류: {e}")
            return 0.0

    def _extract_change_verified(self, soup: BeautifulSoup, current_price: float) -> Tuple[float, float]:
        """전일대비/등락률 추출 - 검증된 방식"""
        try:
            print("🔍 전일대비/등락률 추출 (검증된 방식)...")
            
            change_amount = 0.0
            change_rate = 0.0
            
            # 검증된 방식: p.no_exday > span.blind
            exday_area = soup.find('p', class_='no_exday')
            if exday_area:
                blind_elements = exday_area.find_all('span', class_='blind')
                
                if len(blind_elements) >= 2:
                    amount_text = blind_elements[0].get_text(strip=True)
                    rate_text = blind_elements[1].get_text(strip=True)
                    
                    print(f"    전일대비 원본: '{amount_text}'")
                    print(f"    등락률 원본: '{rate_text}'")
                    
                    # 전일대비 처리
                    if amount_text.startswith(('+', '-')):
                        change_amount = float(amount_text.replace(',', ''))
                    elif amount_text.replace(',', '').replace('.', '').isdigit():
                        amount_value = float(amount_text.replace(',', ''))
                        direction = self._determine_direction_verified(soup, exday_area)
                        change_amount = amount_value if direction == 'up' else -amount_value
                    
                    # 등락률 처리
                    if rate_text.replace('.', '').replace(',', '').isdigit():
                        rate_value = float(rate_text)
                        parent_text = exday_area.get_text() if exday_area else ""
                        if '%' in parent_text:
                            if change_amount > 0:
                                change_rate = abs(rate_value)
                            else:
                                change_rate = -abs(rate_value)
            
            return change_amount, change_rate
            
        except Exception as e:
            print(f"❌ 전일대비/등락률 추출 오류: {e}")
            return 0.0, 0.0

    def _determine_direction_verified(self, soup: BeautifulSoup, target_area: Any) -> str:
        """방향 판단 - 검증된 방식"""
        try:
            # 기호 검색
            page_text = soup.get_text()
            if '▼' in page_text or '↓' in page_text:
                return 'down'
            elif '▲' in page_text or '↑' in page_text:
                return 'up'
            
            # 색상/클래스 분석
            if target_area:
                area_html = str(target_area)
                if any(indicator in area_html.lower() for indicator in ['blue', 'down', 'fall']):
                    return 'down'
                elif any(indicator in area_html.lower() for indicator in ['red', 'up', 'rise']):
                    return 'up'
            
            return 'up'
        except:
            return 'up'

    def _extract_volume_verified(self, soup: BeautifulSoup) -> int:
        """거래량 추출 - 검증된 간단한 방식"""
        try:
            print("🔍 거래량 추출 (검증된 방식)...")
            
            # 방법 1: td 라벨 방식
            td_elements = soup.find_all('td')
            for i, td in enumerate(td_elements):
                td_text = td.get_text(strip=True)
                if td_text == '거래량':
                    # 다음 셀에서 값 찾기
                    if i + 1 < len(td_elements):
                        value_cell = td_elements[i + 1]
                        value_text = value_cell.get_text(strip=True)
                        
                        # 첫 번째 쉼표 있는 숫자 추출
                        match = re.search(r'([\d,]+)', value_text)
                        if match:
                            volume_str = match.group(1)
                            if ',' in volume_str and len(volume_str) >= 4:
                                try:
                                    volume = int(volume_str.replace(',', ''))
                                    if 1 <= volume <= 100000000:
                                        return volume
                                except:
                                    continue
            
            return 0
        except Exception as e:
            print(f"❌ 거래량 추출 오류: {e}")
            return 0

    def _extract_trading_value_verified(self, soup: BeautifulSoup) -> str:
        """거래대금 추출 - 검증된 방식"""
        try:
            print("🔍 거래대금 추출...")
            
            td_elements = soup.find_all('td')
            for i, td in enumerate(td_elements):
                if '거래대금' in td.get_text():
                    if i + 1 < len(td_elements):
                        value_td = td_elements[i + 1]
                        value_text = value_td.get_text(strip=True)
                        if any(unit in value_text for unit in ['백만', '억', '조']):
                            return self._clean_text(value_text)
            
            return ""
        except Exception as e:
            print(f"❌ 거래대금 추출 오류: {e}")
            return ""

    def _extract_market_cap_verified(self, soup: BeautifulSoup) -> str:
        """시가총액 추출 - 검증된 방식"""
        try:
            print("🔍 시가총액 추출...")
            
            td_elements = soup.find_all('td')
            for i, td in enumerate(td_elements):
                if '시가총액' in td.get_text():
                    if i + 1 < len(td_elements):
                        value_td = td_elements[i + 1]
                        value_text = value_td.get_text()
                        market_cap = self._parse_market_cap_verified(value_text)
                        if market_cap:
                            return market_cap
            
            return ""
        except Exception as e:
            print(f"❌ 시가총액 추출 오류: {e}")
            return ""

    def _parse_market_cap_verified(self, text: str) -> str:
        """시가총액 파싱 - 검증된 방식"""
        try:
            cleaned = re.sub(r'\s+', ' ', text).strip()
            
            # 조+억 조합
            combo_pattern = r'(\d{1,3})조\s*(\d{1,4}(?:,\d{3})*)\s*억'
            match = re.search(combo_pattern, cleaned)
            if match:
                jo_part = match.group(1).replace(',', '')
                eok_part = match.group(2).replace(',', '')
                if jo_part.isdigit() and eok_part.isdigit():
                    jo_num = int(jo_part)
                    eok_num = int(eok_part)
                    if 1 <= jo_num <= 1000 and 1 <= eok_num <= 9999:
                        return f"{jo_num}조{eok_num:,}억원"
            
            # 단일 단위
            single_patterns = [
                (r'(\d{1,4}(?:,\d{3})*)\s*조', '조원'),
                (r'(\d{1,6}(?:,\d{3})*)\s*억', '억원')
            ]
            
            for pattern, unit in single_patterns:
                match = re.search(pattern, cleaned)
                if match:
                    number = match.group(1).replace(',', '')
                    if number.isdigit():
                        num = int(number)
                        if (unit == '조원' and 1 <= num <= 1000) or (unit == '억원' and 1 <= num <= 100000):
                            return f"{num:,}{unit}"
            
            return ""
        except:
            return ""

    def _extract_52week_verified(self, soup: BeautifulSoup) -> Tuple[float, float]:
        """52주 최고/최저가 추출 - 검증된 방식"""
        try:
            high_52w = 0.0
            low_52w = 0.0
            
            page_text = soup.get_text()
            
            # 52주 최고가
            high_patterns = [
                r'52주\s*최고[^\d]*?([\d,]+)',
                r'52주\s*고가[^\d]*?([\d,]+)',
            ]
            
            for pattern in high_patterns:
                match = re.search(pattern, page_text)
                if match:
                    try:
                        price = float(match.group(1).replace(',', ''))
                        if 100 < price < 10000000:
                            high_52w = price
                            break
                    except:
                        continue
            
            # 52주 최저가
            low_patterns = [
                r'52주\s*최저[^\d]*?([\d,]+)',
                r'52주\s*저가[^\d]*?([\d,]+)',
            ]
            
            for pattern in low_patterns:
                match = re.search(pattern, page_text)
                if match:
                    try:
                        price = float(match.group(1).replace(',', ''))
                        if 100 < price < 10000000:
                            low_52w = price
                            break
                    except:
                        continue
            
            return high_52w, low_52w
            
        except:
            return 0.0, 0.0

    def _extract_foreign_ownership_verified(self, soup: BeautifulSoup) -> str:
        """외국인지분율 추출 - 검증된 방식"""
        try:
            print("🔍 외국인지분율 추출...")
            
            td_elements = soup.find_all('td')
            for i, td in enumerate(td_elements):
                if '외국인' in td.get_text():
                    for j in range(i, min(len(td_elements), i+3)):
                        candidate_td = td_elements[j]
                        candidate_text = candidate_td.get_text(strip=True)
                        
                        percentage_match = re.search(r'(\d+\.\d+)%', candidate_text)
                        if percentage_match:
                            percentage = percentage_match.group(0)
                            try:
                                value = float(percentage.replace('%', ''))
                                if 0 <= value <= 100:
                                    return percentage
                            except:
                                continue
            
            return ""
        except Exception as e:
            print(f"❌ 외국인지분율 추출 오류: {e}")
            return ""

    def _extract_investment_opinion(self, soup: BeautifulSoup) -> str:
        """투자의견 추출"""
        try:
            td_elements = soup.find_all('td')
            for i, td in enumerate(td_elements):
                td_text = td.get_text()
                if '투자의견' in td_text:
                    for j in range(i, min(len(td_elements), i+3)):
                        candidate_td = td_elements[j]
                        candidate_text = candidate_td.get_text(strip=True)
                        
                        opinions = ['매수', '중립', '매도', 'Buy', 'Hold', 'Sell']
                        for opinion in opinions:
                            if opinion in candidate_text:
                                return self._clean_text(candidate_text)[:30]
            return ""
        except:
            return ""

    def _extract_sector_verified(self, soup: BeautifulSoup) -> Tuple[str, List[str]]:
        """동종업종 추출 - 검증된 간단한 방식"""
        try:
            sector_name = "비교"
            companies = []
            
            # 동종업종 회사들 추출
            tables = soup.find_all('table')
            for table in tables:
                table_text = table.get_text()
                if '동종' in table_text or '업종' in table_text or '비교' in table_text:
                    # 한글 회사명 패턴
                    company_patterns = re.findall(r'([가-힣]{2,10})', table_text)
                    
                    for company in company_patterns:
                        clean_name = company.strip()
                        if (clean_name and 
                            len(clean_name) >= 2 and 
                            clean_name not in companies and
                            len(companies) < 10 and
                            not any(skip in clean_name for skip in ['순위', '업종', '비교', '평균', '종목', '코드'])):
                            companies.append(clean_name)
            
            return sector_name, companies
        except:
            return "비교", []

    def _mathematical_validation_verified(self, current_price: float, change_amount: float, change_rate: float) -> Tuple[float, float]:
        """수학적 검증 - 검증된 방식"""
        try:
            print("🔍 수학적 검증...")
            
            if current_price > 0 and change_amount != 0 and change_rate != 0:
                yesterday_price = current_price - change_amount
                
                if yesterday_price <= 0:
                    change_amount = -change_amount
                    yesterday_price = current_price - change_amount
                
                if yesterday_price > 0:
                    calculated_rate = (change_amount / yesterday_price) * 100
                    rate_diff = abs(calculated_rate - change_rate)
                    
                    print(f"    어제 주가: {yesterday_price:,.0f}원")
                    print(f"    계산된 등락률: {calculated_rate:.2f}%")
                    print(f"    추출된 등락률: {change_rate:.2f}%")
                    print(f"    오차: {rate_diff:.3f}%")
                    
                    if rate_diff > 0.1:
                        print(f"⚠️ 수학적 일치성을 위해 등락률 보정")
                        change_rate = round(calculated_rate, 2)
                        print(f"✅ 등락률 보정: {change_rate:+.2f}%")
                    else:
                        print(f"✅ 수학적 일치성 우수 (오차: {rate_diff:.3f}%)")
            
            return change_amount, change_rate
            
        except Exception as e:
            print(f"❌ 수학적 검증 오류: {e}")
            return change_amount, change_rate

    def _final_validation_verified(self, result: Dict[str, Any]) -> Dict[str, Any]:
        """최종 검증 - 검증된 방식"""
        try:
            # 성공률 계산
            total_fields = 11
            success_count = sum(1 for field in [
                'current_price', 'change_amount', 'change_rate', 'volume',
                'trading_value', 'market_cap', 'high_52w', 'low_52w',
                'foreign_ownership', 'investment_opinion', 'sector_companies'
            ] if result.get(field) not in [None, 0, "", []])

            success_rate = (success_count / total_fields) * 100

            # 수학적 일치성 검증
            current_price = result.get('current_price', 0)
            change_amount = result.get('change_amount', 0)
            change_rate = result.get('change_rate', 0)
            
            mathematical_consistency = "unknown"
            if current_price and change_amount and change_rate:
                yesterday_price = current_price - change_amount
                if yesterday_price > 0:
                    calculated_rate = (change_amount / yesterday_price) * 100
                    rate_diff = abs(calculated_rate - change_rate)
                    
                    if rate_diff < 0.01:
                        mathematical_consistency = "perfect"
                    elif rate_diff < 0.1:
                        mathematical_consistency = "excellent"
                    elif rate_diff < 0.5:
                        mathematical_consistency = "good"
                    else:
                        mathematical_consistency = "acceptable"

            # 품질 등급
            if success_rate >= 90 and mathematical_consistency in ["perfect", "excellent"]:
                quality_grade = "🏆 완벽"
            elif success_rate >= 80:
                quality_grade = "🥇 우수"
            elif success_rate >= 70:
                quality_grade = "🥈 양호"
            else:
                quality_grade = "🥉 보통"

            result['quality_assessment'] = {
                'success_rate': success_rate,
                'success_count': success_count,
                'total_fields': total_fields,
                'mathematical_consistency': mathematical_consistency,
                'quality_grade': quality_grade
            }

            return result
        except:
            return result

    def _clean_text(self, text: str) -> str:
        """텍스트 정리"""
        if not text:
            return ""
        cleaned = re.sub(r'\s+', ' ', text).strip()
        return cleaned

    def _print_final_result(self, result: Dict[str, Any]):
        """최종 결과 출력"""
        
        print(f"회사명: {result['company_name']}")
        print(f"종목코드: {result['stock_code']}")

        print(f"\n💰 실시간 주가 정보:")
        print(f"  현재가: {result['current_price']:,}원" if result['current_price'] else "  현재가: 추출 실패")
        
        change_amount = result['change_amount']
        change_rate = result['change_rate']
        
        if change_amount and change_rate:
            direction = result['direction']
