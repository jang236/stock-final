            # 전일대비/등락률 추출 (검증된 방식)
            change_amount, change_rate = self._extract_change_verified(soup, current_price)
            direction = "상승 ⬆️" if change_amount > 0 else "하락 ⬇️" if change_amount < 0 else "보합"
